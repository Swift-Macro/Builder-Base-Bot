    background: #c28a4b;
    border-radius: 6px;

    border: 1px solid #2b1a0f;
}

QSlider::add-page:horizontal {
    background: #3b2413;
    border-radius: 6px;
}

QSlider::handle:horizontal {
    background-color: #c28a4b;

    border-radius: 11px;
    border: 2px solid #2b1a0f;

    border-top-color: #f1b56e;
    border-left-color: #f1b56e;
    border-bottom-color: #5c381d;
