                  <property name="styleSheet">
                   <string notr="true">QListWidget {
    background-color: rgba(90, 55, 28, 235);
    border-radius: 16px;
    border: 3px solid #2b1a0f;

    /* lighting illusion */
    border-top-color: #7a4d28;
    border-left-color: #7a4d28;
    border-bottom-color: #140c06;
    border-right-color: #140c06;
}

/* normal items = square-ish with rounded corners */
QListWidget::item {
    border-radius: 6px; /* small rounding for square shape */
}

/* hover effect */
QListWidget::item:hover {
    background-color: rgba(255, 255, 255, 30); /* subtle highlight */
    border-radius: 6px;
}

/* item pressed = looks pushed down */
QListWidget::item:pressed {
    background-color: rgba(0, 0, 0, 40);
    border-top: 2px solid #140c06;
    border-left: 2px solid #140c06;
    border-bottom: 2px solid #7a4d28;
    border-right: 2px solid #7a4d28;
    border-radius: 6px;
}

/* keep the pressed look when selected */
QListWidget::item:selected {
    background-color: rgba(0, 0, 0, 30);
    border-top: 2px solid #140c06;
    border-left: 2px solid #140c06;
    border-bottom: 2px solid #7a4d28;
    border-right: 2px solid #7a4d28;
    border-radius: 6px;
}</string>
                  </property>
                  <property name="verticalScrollMode">
                   <enum>QAbstractItemView::ScrollMode::ScrollPerItem</enum>
                  </property>
                  <property name="batchSize">
                   <number>100</number>
                  </property>
                  <property name="sortingEnabled">
