            <item>
             <widget class="QPushButton" name="maxWallsBtn">
              <property name="sizePolicy">
               <sizepolicy hsizetype="Preferred" vsizetype="Preferred">
                <horstretch>0</horstretch>
                <verstretch>0</verstretch>
               </sizepolicy>
              </property>
              <property name="font">
               <font>
                <pointsize>10</pointsize>
                <bold>true</bold>
               </font>
              </property>
              <property name="cursor">
               <cursorShape>PointingHandCursor</cursorShape>
              </property>
              <property name="styleSheet">
               <string notr="true">QPushButton {

    /* Warm orange gradient */
    background-color: qlineargradient(
        x1:0, y1:0,
        x2:0, y2:1,
        stop:0 #F7B24D,
        stop:0.5 #E98A2A,
        stop:1 #C86A1A
    );

    color: #FFFFFF;

    /* Thick dark brown border */
    border: 4px solid #6A3B12;
    border-radius: 16px;

    /* Slight inner feel */
    padding: 10px 16px;

    font-weight: bold;
}


/* HOVER — brighter, more golden */
QPushButton:hover {

    background-color: qlineargradient(
        x1:0, y1:0,
        x2:0, y2:1,
        stop:0 #FFC766,
        stop:0.5 #F29A33,
        stop:1 #D9781F
    );
}


/* PRESSED — darker + pressed depth */
QPushButton:pressed {

    background-color: qlineargradient(
        x1:0, y1:0,
        x2:0, y2:1,
        stop:0 #C86A1A,
        stop:0.5 #A95514,
        stop:1 #7F3E0E
    );

    /* Push-down effect */
    padding-top: 12px;
    padding-bottom: 8px;
}


/* CHECKED — highlighted */
QPushButton:checked {

    background-color: qlineargradient(
        x1:0, y1:0,
        x2:0, y2:1,
        stop:0 #FFD27A,
        stop:0.5 #F2A23D,
        stop:1 #C86A1A
    );

    border: 4px solid #FFD27A;
}</string>
