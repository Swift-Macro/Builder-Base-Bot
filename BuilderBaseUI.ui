                <property name="styleSheet">
                 <string notr="true">/* ======================
   ATTACK BUTTON (GREEN)
====================== */

QPushButton {
    background-color: #4CAF50;
    color: white;
    border-radius: 10px;
    padding: 8px;
    font-weight: bold;
    border: 3px solid #2e7d32;
}


/* hover */
QPushButton:hover {
    background-color: #66cc66;
}


/* pressed (clicking) */
QPushButton:pressed {
    background-color: #2e7d32;

    /* push-down effect */
    padding-top: 10px;
    padding-bottom: 6px;
}


/* stays highlighted when active */
QPushButton#attackButton:checked {
    background-color: #43a047;
    border: 3px solid #a5d6a7;
}</string>
